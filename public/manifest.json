{
  "manifest_version": 3,
  "name": "FocusFlow",
  "version": "1.0.0",
  "description": "Intent-aware productivity assistant",

  "action": {
    "default_popup": "index.html",
    "default_title": "FocusFlow"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
  "storage",
  "tabs",
  "notifications"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "icons": {
    "128": "icon.png"
  }
}